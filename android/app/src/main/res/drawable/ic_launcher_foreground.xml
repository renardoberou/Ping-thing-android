<?xml version="1.0" encoding="utf-8"?>
<!-- Resonant Systems brand mark: phosphor radar rings + three enemies.
     Circles drawn as twin-arc paths (vector drawables have no circle element). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ring r=30 -->
    <path
        android:pathData="M 24,54 a 30,30 0 1,0 60,0 a 30,30 0 1,0 -60,0"
        android:strokeColor="#00DD88"
        android:strokeWidth="3.5"
        android:strokeAlpha="0.9"
        android:fillColor="#00000000" />

    <!-- Middle ring r=21 -->
    <path
        android:pathData="M 33,54 a 21,21 0 1,0 42,0 a 21,21 0 1,0 -42,0"
        android:strokeColor="#00DD88"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.55"
        android:fillColor="#00000000" />

    <!-- Inner ring r=13 -->
    <path
        android:pathData="M 41,54 a 13,13 0 1,0 26,0 a 13,13 0 1,0 -26,0"
        android:strokeColor="#00DD88"
        android:strokeWidth="2"
        android:strokeAlpha="0.35"
        android:fillColor="#00000000" />

    <!-- Enemy: gold (54,33) r=4.5 -->
    <path
        android:pathData="M 49.5,33 a 4.5,4.5 0 1,0 9,0 a 4.5,4.5 0 1,0 -9,0"
        android:fillColor="#C89040" />

    <!-- Enemy: blue (63,60) r=3.5 -->
    <path
        android:pathData="M 59.5,60 a 3.5,3.5 0 1,0 7,0 a 3.5,3.5 0 1,0 -7,0"
        android:fillColor="#5090C0" />

    <!-- Enemy: green (44,62) r=4 -->
    <path
        android:pathData="M 40,62 a 4,4 0 1,0 8,0 a 4,4 0 1,0 -8,0"
        android:fillColor="#22AA66" />
</vector>
